POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=steam_tracker
POSTGRES_PORT=5432

BACKEND_PORT=3000
OPENAPI_ENABLED=true
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/steam_tracker

STEAM_API_KEY=
STEAM_API_BASE_URL=https://api.steampowered.com

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
SYNC_QUEUE_NAME=steam-sync

STEAM_API_CACHE_ENABLED=true
STEAM_API_CACHE_NAMESPACE=steam:v1
STEAM_API_CACHE_PROFILE_TTL_SECONDS=600
STEAM_API_CACHE_OWNED_GAMES_TTL_SECONDS=1800
STEAM_API_CACHE_SCHEMA_TTL_SECONDS=1209600
STEAM_API_CACHE_GLOBAL_PERCENTAGES_TTL_SECONDS=43200
STEAM_API_CACHE_PLAYER_ACHIEVEMENTS_TTL_SECONDS=120
